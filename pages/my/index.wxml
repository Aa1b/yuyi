<t-toast id="t-toast" />

<view class="my">
  <image class="nav-bg" src="/static/bg_navbar.png" />
  <nav title-text="我的" />
  <view class="my-info">
    <t-cell-group>
      <t-cell wx:if="{{isLoad && isLoggedIn}}" bordered="{{false}}">
        <t-avatar image="{{personalInfo.image}}" slot="left-icon" size="large" />
        <view class="my-info__person" slot="description">
          <view class="name">{{personalInfo.name}}</view>
          <view class="my-info__stats">
            <view class="my-info__stat" bindtap="onGoProfile">
              <text class="my-info__stat-value">{{personalInfo.recordCount || 0}}</text>
              <text class="my-info__stat-label">记录</text>
            </view>
            <view class="my-info__stat" bindtap="onGoFollowing">
              <text class="my-info__stat-value">{{personalInfo.followingCount || 0}}</text>
              <text class="my-info__stat-label">关注</text>
            </view>
            <view class="my-info__stat" bindtap="onGoFollowers">
              <text class="my-info__stat-value">{{personalInfo.followerCount || 0}}</text>
              <text class="my-info__stat-label">粉丝</text>
            </view>
            <view class="my-info__stat">
              <text class="my-info__stat-value">{{personalInfo.likeCount || 0}}</text>
              <text class="my-info__stat-label">获赞</text>
            </view>
          </view>
          <view class="tags">
            <t-tag class="tag" variant="light" icon="discount">{{personalInfo.star}}</t-tag>
            <t-tag class="tag" variant="light" icon="location">{{personalInfo.city}}</t-tag>
          </view>
        </view>
        <t-icon slot="right-icon" name="edit" size="40rpx" color="#000000e6" bindtap="onNavigateTo" />
      </t-cell>
      <t-cell
        wx:if="{{isLoad && !isLoggedIn}}"
        title="请先登录/注册"
        bordered="{{false}}"
        t-class-title="cell-class-title"
        t-class-center="cell-class-center"
        bindtap="onLogin"
      >
        <t-avatar slot="left-icon" icon="user" size="128rpx" />
      </t-cell>
    </t-cell-group>
    <t-divider t-class="divider-class" />
    <t-grid t-class="grid-class">
      <t-grid-item
        wx:for="{{gridList}}"
        wx:for-item="gridItem"
        wx:key="type"
        text="{{gridItem.name}}"
        icon="{{gridItem.icon}}"
        class="grid-item {{gridItem.type === 'all' ? 'split-line' : ''}}"
        data-data="{{gridItem}}"
        bindclick="onEleClick"
      />
    </t-grid>
  </view>

  <t-cell-group theme="card">
    <t-cell
      wx:for="{{settingList}}"
      wx:for-item="item"
      wx:key="type"
      title="{{item.name}}"
      url="{{item.url || ''}}"
      leftIcon="{{item.type === 'admin' ? '' : item.icon}}"
      hover
      arrow
      data-data="{{item}}"
      bindclick="onEleClick"
    >
      <t-icon wx:if="{{item.type === 'admin'}}" slot="left-icon" name="check-circle" size="40rpx" />
    </t-cell>
  </t-cell-group>
</view>
