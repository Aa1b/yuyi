<t-navbar title="修改密码" left-arrow />
<view class="change-password">
  <view class="form">
    <view class="form-item">
      <text class="label">原密码</text>
      <input class="input" type="password" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldInput" />
    </view>
    <view class="form-item">
      <text class="label">新密码</text>
      <input class="input" type="password" placeholder="至少6位" value="{{newPassword}}" bindinput="onNewInput" />
    </view>
    <view class="form-item">
      <text class="label">确认新密码</text>
      <input class="input" type="password" placeholder="再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmInput" />
    </view>
    <t-button theme="primary" block loading="{{loading}}" bindtap="onSubmit" class="submit-btn">确认修改</t-button>
  </view>
  <view class="tip">仅邮箱注册的账号可修改密码</view>
</view>
<t-message id="t-message" />
